{
  "manifest_version": 3,
  "name": "Price Tracker Alert",
  "version": "1.0",
  "description": "Track Amazon product prices and send Alerts!!     -Built by Vvk~",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://www.amazon.in/*",
    "http://127.0.0.1:5000/*"
  ],
  "action": {
    "default_popup": "dist/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.amazon.in/*"],
      "js": ["content.js"]
    }
  ]
}